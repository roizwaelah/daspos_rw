<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DasPos" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_green_dark</item>
        <item name="colorOnPrimary">@color/surface_white</item>
        <item name="colorSurface">@color/surface_white</item>
        <item name="android:statusBarColor">@color/primary_green_dark</item>
    </style>

    <style name="DasPosToolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/primary_green</item>
        <item name="titleTextColor">@color/surface_white</item>
        <item name="navigationIconTint">@color/surface_white</item>
    </style>

    <style name="DasPosPrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_green</item>
        <item name="android:textColor">@color/surface_white</item>
        <item name="android:textSize">12sp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="DasPosOutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_green</item>
        <item name="android:textColor">@color/primary_green</item>
        <item name="cornerRadius">12sp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="DasPosDangerButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/danger_red</item>
        <item name="android:textColor">@color/surface_white</item>
        <item name="cornerRadius">12sp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="DasPosGrayButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_gray</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">12sp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="DasPosTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary_green</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="DasPosSectionCard">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="DasPosSectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DasPosFieldLabel">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>
